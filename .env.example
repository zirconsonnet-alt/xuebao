# Copy this file to .env on the Linux server and replace every placeholder.

# Bot runtime
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO
SUPERUSERS=[]
COMMAND_START=["/"]

# Optional service integrations
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=
DAILY_RELEASE_GROUP_IDS=
SUNO_API_BASE_URL=

# Deployment paths on the server host.
XUEBAO_DATA_DIR=./data
XUEBAO_CACHE_DIR=./cache
XUEBAO_CONFIG_DIR=./config
XUEBAO_BACKUP_DIR=./backups
XUEBAO_BACKUP_ON_DEPLOY=true

# Push-to-deploy branch. Keep this aligned with .github/workflows/deploy.yml.
DEPLOY_BRANCH=main
